# ============================================================
# ICS Booking System - Environment Variables
# ============================================================
# Copy this file to .env for local development
# For production (Render), set these in the Dashboard > Environment

# ============================================================
# SECURITY (Required)
# ============================================================
# Generate secure random keys for production!
# Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ============================================================
# ENVIRONMENT
# ============================================================
# Options: development, production
FLASK_ENV=development

# ============================================================
# DATABASE (Optional - defaults shown)
# ============================================================
# For local development:
# DATABASE_PATH=cleaning_service.db
#
# For Render production (handled automatically):
# DATABASE_DIR=/opt/render/project/src

# ============================================================
# EMAIL CONFIGURATION (Required for invoice emails)
# ============================================================
# For Gmail:
# 1. Enable 2-Step Verification on your Google Account
# 2. Create an App Password: Google Account > Security > App passwords
# 3. Use the 16-character app password below

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_SENDER_NAME=Intelligence Cleaning Services
MAIL_ENABLED=true

# ============================================================
# CORS CONFIGURATION (Optional)
# ============================================================
# For development, leave as * to allow all origins
# For production, specify your domains (comma-separated)
# Example: https://ics-website.onrender.com,https://ics-admin.onrender.com
ALLOWED_ORIGINS=*

# ============================================================
# RENDER-SPECIFIC (Set automatically by Render)
# ============================================================
# PORT=10000  # Render assigns this automatically
